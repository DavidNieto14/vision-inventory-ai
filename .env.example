# ── Modelo ────────────────────────────────────────────────────────────────────
MODEL_PATH=models/best.pt
MODEL_CONFIDENCE=0.5
MODEL_IOU_THRESHOLD=0.45
DEVICE=cpu                  # cpu | cuda | mps

# ── Base de datos ─────────────────────────────────────────────────────────────
